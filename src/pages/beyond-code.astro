---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/ui/Navigation.astro';
import MountainScene from '../components/3d/MountainScene';
---

<Layout title="Beyond Code | Nick Stafford">
  <!-- 3D Mountain Background -->
  <MountainScene client:load />

  <!-- Navigation -->
  <Navigation />

  <!-- Main Content -->
  <main class="relative z-10 min-h-screen">
    <!-- Hero Section -->
    <section class="min-h-screen flex items-center justify-center px-6 pt-20">
      <div class="text-center max-w-4xl mx-auto">
        <span class="inline-block px-4 py-2 rounded-full text-sm font-medium mb-6"
          style="background: rgba(99, 91, 255, 0.2); color: var(--color-accent-primary); border: 1px solid rgba(99, 91, 255, 0.3);">
          Life Outside the Terminal
        </span>
        <h1 class="text-5xl md:text-7xl font-bold mb-6" style="color: var(--color-text-primary);">
          Beyond <span class="gradient-text">Code</span>
        </h1>
        <p class="text-xl md:text-2xl mb-8 max-w-2xl mx-auto" style="color: var(--color-text-secondary);">
          When I'm not writing code, you'll find me chasing peaks, exploring trails, and finding perspective in the mountains.
        </p>
        <div class="flex items-center justify-center gap-4 text-sm" style="color: var(--color-text-muted);">
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Colorado & Beyond
          </span>
          <span>•</span>
          <span>Hiker</span>
          <span>•</span>
          <span>Photographer</span>
        </div>

        <!-- Scroll indicator -->
        <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
          <svg class="w-6 h-6" style="color: var(--color-text-muted);" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
        </div>
      </div>
    </section>

    <!-- Adventures Grid -->
    <section class="py-20 px-6">
      <div class="container mx-auto max-w-6xl">
        <div class="text-center mb-16">
          <span class="section-label">Adventures</span>
          <h2 class="text-4xl font-bold" style="color: var(--color-text-primary);">
            Recent Expeditions
          </h2>
        </div>

        <!-- Adventure Cards - Placeholder for your actual adventures -->
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          <!-- Adventure Card Template -->
          <article class="group relative overflow-hidden rounded-2xl aspect-[4/5]"
            style="background: var(--color-bg-surface); border: 1px solid var(--color-border);">
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent z-10"></div>

            <!-- Placeholder for image -->
            <div class="absolute inset-0 flex items-center justify-center" style="background: linear-gradient(135deg, rgba(99, 91, 255, 0.2) 0%, rgba(0, 212, 255, 0.1) 100%);">
              <svg class="w-16 h-16 opacity-30" style="color: var(--color-text-muted);" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>

            <div class="absolute bottom-0 left-0 right-0 p-6 z-20">
              <div class="flex items-center gap-2 mb-2">
                <span class="px-2 py-1 rounded text-xs font-medium" style="background: rgba(99, 91, 255, 0.3); color: var(--color-accent-primary);">
                  Hiking
                </span>
                <span class="text-xs" style="color: var(--color-text-muted);">Coming Soon</span>
              </div>
              <h3 class="text-xl font-bold mb-1" style="color: var(--color-text-primary);">
                Your Adventure Title
              </h3>
              <p class="text-sm" style="color: var(--color-text-secondary);">
                Add your adventure stories and photos here...
              </p>
            </div>
          </article>

          <!-- Add more adventure cards as needed -->
          <article class="group relative overflow-hidden rounded-2xl aspect-[4/5]"
            style="background: var(--color-bg-surface); border: 1px solid var(--color-border);">
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent z-10"></div>
            <div class="absolute inset-0 flex items-center justify-center" style="background: linear-gradient(135deg, rgba(16, 185, 129, 0.2) 0%, rgba(99, 91, 255, 0.1) 100%);">
              <svg class="w-16 h-16 opacity-30" style="color: var(--color-text-muted);" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <div class="absolute bottom-0 left-0 right-0 p-6 z-20">
              <div class="flex items-center gap-2 mb-2">
                <span class="px-2 py-1 rounded text-xs font-medium" style="background: rgba(16, 185, 129, 0.3); color: #10b981;">
                  Camping
                </span>
                <span class="text-xs" style="color: var(--color-text-muted);">Coming Soon</span>
              </div>
              <h3 class="text-xl font-bold mb-1" style="color: var(--color-text-primary);">
                Another Adventure
              </h3>
              <p class="text-sm" style="color: var(--color-text-secondary);">
                Your story goes here...
              </p>
            </div>
          </article>

          <article class="group relative overflow-hidden rounded-2xl aspect-[4/5]"
            style="background: var(--color-bg-surface); border: 1px solid var(--color-border);">
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent z-10"></div>
            <div class="absolute inset-0 flex items-center justify-center" style="background: linear-gradient(135deg, rgba(245, 158, 11, 0.2) 0%, rgba(99, 91, 255, 0.1) 100%);">
              <svg class="w-16 h-16 opacity-30" style="color: var(--color-text-muted);" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <div class="absolute bottom-0 left-0 right-0 p-6 z-20">
              <div class="flex items-center gap-2 mb-2">
                <span class="px-2 py-1 rounded text-xs font-medium" style="background: rgba(245, 158, 11, 0.3); color: #f59e0b;">
                  Summit
                </span>
                <span class="text-xs" style="color: var(--color-text-muted);">Coming Soon</span>
              </div>
              <h3 class="text-xl font-bold mb-1" style="color: var(--color-text-primary);">
                Peak Adventure
              </h3>
              <p class="text-sm" style="color: var(--color-text-secondary);">
                Your summit story here...
              </p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="py-20 px-6" style="background: rgba(10, 10, 15, 0.8);">
      <div class="container mx-auto max-w-4xl">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
          <div>
            <div class="text-4xl md:text-5xl font-bold gradient-text mb-2">--</div>
            <div class="text-sm" style="color: var(--color-text-muted);">Peaks Summited</div>
          </div>
          <div>
            <div class="text-4xl md:text-5xl font-bold gradient-text mb-2">--</div>
            <div class="text-sm" style="color: var(--color-text-muted);">Miles Hiked</div>
          </div>
          <div>
            <div class="text-4xl md:text-5xl font-bold gradient-text mb-2">--</div>
            <div class="text-sm" style="color: var(--color-text-muted);">States Explored</div>
          </div>
          <div>
            <div class="text-4xl md:text-5xl font-bold gradient-text mb-2">--</div>
            <div class="text-sm" style="color: var(--color-text-muted);">National Parks</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Philosophy Section -->
    <section class="py-20 px-6">
      <div class="container mx-auto max-w-3xl text-center">
        <blockquote class="text-2xl md:text-3xl font-light italic mb-6" style="color: var(--color-text-secondary);">
          "The mountains are calling and I must go."
        </blockquote>
        <cite class="text-sm" style="color: var(--color-text-muted);">— John Muir</cite>

        <div class="mt-12 p-8 rounded-2xl" style="background: var(--color-bg-surface); border: 1px solid var(--color-border);">
          <h3 class="text-xl font-bold mb-4" style="color: var(--color-text-primary);">
            Why the Mountains?
          </h3>
          <p style="color: var(--color-text-secondary);">
            Add your personal story here - why outdoor adventures matter to you,
            how they connect to your work, and what you've learned from the trails...
          </p>
        </div>
      </div>
    </section>

    <!-- Back to Main -->
    <section class="py-12 px-6 text-center">
      <a href="/" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg transition-all hover:scale-105"
        style="background: var(--color-bg-surface); border: 1px solid var(--color-border); color: var(--color-text-primary);">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Portfolio
      </a>
    </section>
  </main>
</Layout>

<style>
  .gradient-text {
    background: linear-gradient(135deg, #635BFF 0%, #00D4FF 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent-primary);
    margin-bottom: 0.5rem;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0) translateX(-50%); }
    50% { transform: translateY(-10px) translateX(-50%); }
  }

  .animate-bounce {
    animation: bounce 2s infinite;
  }
</style>
