---
// Navigation with glassmorphic blur effect
---

<header id="nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <nav class="container mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group">
      <!-- Mountain Logo SVG -->
      <div class="w-10 h-10 relative">
        <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
          <!-- Gradient definitions -->
          <defs>
            <linearGradient id="mountainGrad" x1="0%" y1="100%" x2="100%" y2="0%">
              <stop offset="0%" style="stop-color:#4B5563" />
              <stop offset="50%" style="stop-color:#6B7280" />
              <stop offset="100%" style="stop-color:#9CA3AF" />
            </linearGradient>
            <linearGradient id="peakGrad" x1="0%" y1="100%" x2="100%" y2="0%">
              <stop offset="0%" style="stop-color:#635BFF" />
              <stop offset="100%" style="stop-color:#00D4FF" />
            </linearGradient>
            <linearGradient id="snowGrad" x1="0%" y1="0%" x2="0%" y2="100%">
              <stop offset="0%" style="stop-color:#F0F0F5" />
              <stop offset="100%" style="stop-color:#9CA3AF" />
            </linearGradient>
          </defs>

          <!-- Back mountain -->
          <path d="M8 32 L20 12 L32 32 Z" fill="url(#mountainGrad)" opacity="0.6" />

          <!-- Front mountain with accent -->
          <path d="M4 32 L18 8 L32 32 Z" fill="url(#mountainGrad)" />

          <!-- Snow cap / Peak highlight -->
          <path d="M18 8 L14 16 L18 14 L22 16 Z" fill="url(#snowGrad)" />

          <!-- Accent line on peak -->
          <path d="M18 8 L18 14" stroke="url(#peakGrad)" stroke-width="2" stroke-linecap="round" class="group-hover:stroke-[3px] transition-all" />

          <!-- Small accent triangle -->
          <path d="M26 32 L32 20 L38 32 Z" fill="url(#peakGrad)" opacity="0.8" />
        </svg>
      </div>

      <span class="font-semibold text-lg text-text-primary group-hover:text-accent-primary transition-colors">
        Nick Stafford
      </span>
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden md:flex items-center gap-8">
      <a href="/#about" class="nav-link">About</a>
      <a href="/#projects" class="nav-link">Projects</a>
      <a href="/#experience" class="nav-link">Experience</a>
      <a href="/#contact" class="nav-link">Contact</a>
      <a href="/beyond-code" class="nav-link flex items-center gap-1.5 group">
        <svg class="w-4 h-4 opacity-70 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M8 21l4-10 4 10M12 11V3M4 21l4-10M20 21l-4-10" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Beyond Code
      </a>
    </div>

    <!-- CTA Button -->
    <div class="hidden md:block">
      <a href="#contact" class="btn btn-primary text-sm">
        Let's Talk
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button id="mobile-menu-btn" class="md:hidden p-2 text-text-secondary hover:text-text-primary transition-colors">
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden absolute top-full left-0 right-0 nav-blur border-t border-border-light">
    <div class="container py-4 flex flex-col gap-4">
      <a href="/#about" class="nav-link py-2">About</a>
      <a href="/#projects" class="nav-link py-2">Projects</a>
      <a href="/#experience" class="nav-link py-2">Experience</a>
      <a href="/#contact" class="nav-link py-2">Contact</a>
      <a href="/beyond-code" class="nav-link py-2 flex items-center gap-2">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M8 21l4-10 4 10M12 11V3M4 21l4-10M20 21l-4-10" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Beyond Code
      </a>
      <a href="/#contact" class="btn btn-primary mt-2">Let's Talk</a>
    </div>
  </div>
</header>

<script>
  // Add blur effect on scroll
  const nav = document.getElementById('nav');
  let lastScroll = 0;

  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY;

    if (currentScroll > 50) {
      nav?.classList.add('nav-blur');
    } else {
      nav?.classList.remove('nav-blur');
    }

    lastScroll = currentScroll;
  });

  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  // Close mobile menu on link click
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
    });
  });
</script>

<style>
  /* Custom Tailwind-compatible colors */
  .text-text-primary { color: var(--color-text-primary); }
  .text-text-secondary { color: var(--color-text-secondary); }
  .text-accent-primary { color: var(--color-accent-primary); }
  .border-border-light { border-color: var(--color-border-light); }
</style>
