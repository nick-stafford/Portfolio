---
// Contact section with form and AI chat teaser
---

<section id="contact" class="py-24 relative overflow-hidden">
  <!-- Background accents -->
  <div class="absolute bottom-0 left-0 w-1/2 h-full opacity-20 pointer-events-none"
    style="background: radial-gradient(ellipse at 0% 100%, var(--color-accent-glow) 0%, transparent 70%);">
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="section-header">
      <span class="section-label">Get in Touch</span>
      <h2 class="text-4xl font-bold" style="color: var(--color-text-primary);">Let's Build Something Together</h2>
      <p class="mt-4 max-w-2xl mx-auto" style="color: var(--color-text-secondary);">
        Have a project in mind? Looking for an AI/financial software expert?
        I'd love to hear from you.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 max-w-5xl mx-auto">
      <!-- Contact Form -->
      <div class="glass-card">
        <form class="space-y-6" id="contact-form">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-medium mb-2" style="color: var(--color-text-secondary);">
                Name
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 rounded-xl transition-all focus:outline-none focus:ring-2"
                style="background: var(--color-bg-surface); border: 1px solid var(--color-border); color: var(--color-text-primary);"
                placeholder="Your name"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium mb-2" style="color: var(--color-text-secondary);">
                Email
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 rounded-xl transition-all focus:outline-none focus:ring-2"
                style="background: var(--color-bg-surface); border: 1px solid var(--color-border); color: var(--color-text-primary);"
                placeholder="your@email.com"
              />
            </div>
          </div>

          <div>
            <label for="subject" class="block text-sm font-medium mb-2" style="color: var(--color-text-secondary);">
              Subject
            </label>
            <select
              id="subject"
              name="subject"
              class="w-full px-4 py-3 rounded-xl transition-all focus:outline-none focus:ring-2"
              style="background: var(--color-bg-surface); border: 1px solid var(--color-border); color: var(--color-text-primary);"
            >
              <option value="project">Project Inquiry</option>
              <option value="consulting">Consulting Request</option>
              <option value="job">Job Opportunity</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium mb-2" style="color: var(--color-text-secondary);">
              Message
            </label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full px-4 py-3 rounded-xl transition-all focus:outline-none focus:ring-2 resize-none"
              style="background: var(--color-bg-surface); border: 1px solid var(--color-border); color: var(--color-text-primary);"
              placeholder="Tell me about your project or inquiry..."
            ></textarea>
          </div>

          <button type="submit" class="btn btn-primary w-full">
            Send Message
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
            </svg>
          </button>
        </form>
      </div>

      <!-- AI Chat Teaser & Direct Contact -->
      <div class="space-y-6">
        <!-- AI Chat Card -->
        <div class="glass-card relative overflow-hidden">
          <div class="absolute top-0 right-0 w-32 h-32 opacity-20 pointer-events-none"
            style="background: radial-gradient(circle, var(--color-accent-primary) 0%, transparent 70%);">
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0"
              style="background: var(--gradient-primary);">
              <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-bold mb-2" style="color: var(--color-text-primary);">
                Chat with AI Assistant
              </h3>
              <p class="text-sm mb-4" style="color: var(--color-text-secondary);">
                Have questions about my work? My AI assistant knows about my projects,
                skills, and experience. Available 24/7.
              </p>
              <button id="open-chat" class="btn btn-secondary text-sm">
                Start Chat
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </button>
            </div>
          </div>
        </div>

        <!-- Direct contact options -->
        <div class="glass-card">
          <h3 class="text-lg font-bold mb-6" style="color: var(--color-text-primary);">
            Or reach out directly
          </h3>

          <div class="space-y-4">
            <a href="mailto:nicholas.alexander.stafford@gmail.com"
              class="flex items-center gap-4 p-4 rounded-xl transition-all hover:-translate-y-1"
              style="background: var(--color-bg-surface); border: 1px solid var(--color-border);">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center"
                style="background: rgba(99, 91, 255, 0.1);">
                <svg class="w-5 h-5" style="color: var(--color-accent-primary);" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="font-medium" style="color: var(--color-text-primary);">Email</p>
                <p class="text-sm" style="color: var(--color-text-secondary);">nicholas.alexander.stafford@gmail.com</p>
              </div>
            </a>

            <a href="https://linkedin.com/in/nickastafford23" target="_blank" rel="noopener"
              class="flex items-center gap-4 p-4 rounded-xl transition-all hover:-translate-y-1"
              style="background: var(--color-bg-surface); border: 1px solid var(--color-border);">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center"
                style="background: rgba(0, 212, 255, 0.1);">
                <svg class="w-5 h-5" style="color: var(--color-accent-secondary);" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </div>
              <div>
                <p class="font-medium" style="color: var(--color-text-primary);">LinkedIn</p>
                <p class="text-sm" style="color: var(--color-text-secondary);">linkedin.com/in/nickastafford23</p>
              </div>
            </a>

            <a href="https://github.com/nick-stafford" target="_blank" rel="noopener"
              class="flex items-center gap-4 p-4 rounded-xl transition-all hover:-translate-y-1"
              style="background: var(--color-bg-surface); border: 1px solid var(--color-border);">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center"
                style="background: rgba(16, 185, 129, 0.1);">
                <svg class="w-5 h-5" style="color: var(--color-success);" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
              </div>
              <div>
                <p class="font-medium" style="color: var(--color-text-primary);">GitHub</p>
                <p class="text-sm" style="color: var(--color-text-secondary);">github.com/nick-stafford</p>
              </div>
            </a>
          </div>
        </div>

        <!-- Location -->
        <div class="text-center p-6" style="color: var(--color-text-muted);">
          <svg class="w-5 h-5 inline-block mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          Based in Seattle, WA - Open to remote opportunities worldwide
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="py-8 border-t" style="border-color: var(--color-border);">
  <div class="container mx-auto px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-sm" style="color: var(--color-text-muted);">
        2026 Nick Stafford. Built with Astro, React Three Fiber, and GSAP.
      </p>
      <div class="flex items-center gap-6">
        <a href="#hero" class="text-sm transition-colors hover:text-accent-primary" style="color: var(--color-text-muted);">
          Back to top
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  input:focus, select:focus, textarea:focus {
    --tw-ring-color: var(--color-accent-primary);
    border-color: var(--color-accent-primary);
  }

  input::placeholder, textarea::placeholder {
    color: var(--color-text-muted);
  }

  .hover\:text-accent-primary:hover {
    color: var(--color-accent-primary);
  }
</style>

<script>
  // Form submission handler (placeholder)
  const form = document.getElementById('contact-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    // TODO: Implement actual form submission
    alert('Form submitted! (Backend integration pending)');
  });

  // AI Chat button handler
  const chatBtn = document.getElementById('open-chat');
  chatBtn?.addEventListener('click', () => {
    // TODO: Open AI chat modal
    alert('AI Chat coming soon!');
  });
</script>
