---
// About section with skills and philosophy
import Philosophy from './Philosophy';
---

<section id="about" class="py-24 relative overflow-hidden">
  <!-- Background accent -->
  <div class="absolute top-0 right-0 w-1/2 h-full opacity-30 pointer-events-none"
    style="background: radial-gradient(ellipse at 100% 0%, var(--color-accent-glow) 0%, transparent 70%);">
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left column: Philosophy, Photo and quick stats -->
      <div class="space-y-8">
        <!-- Philosophy - Fast → Adaptive → Together -->
        <div class="mb-4">
          <Philosophy client:visible />
        </div>

        <!-- Profile card -->
        <div class="glass-card relative overflow-hidden">
          <!-- Profile Photo -->
          <div class="aspect-square max-w-xs mx-auto rounded-2xl overflow-hidden mb-6 relative group">
            <img
              src="/images/nick-headshot.jpg"
              alt="Nick Stafford - AI Solutions Architect"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <!-- Subtle gradient overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          </div>

          <!-- Quick info -->
          <div class="text-center">
            <h3 class="text-2xl font-bold mb-2" style="color: var(--color-text-primary);">Nick Stafford</h3>
            <p class="mb-4" style="color: var(--color-accent-primary);">Seattle, WA</p>
            <div class="flex justify-center gap-4 mb-6">
              <a href="https://linkedin.com/in/nickastafford23" target="_blank" rel="noopener"
                class="p-3 rounded-lg transition-all hover:-translate-y-1"
                style="background: var(--color-bg-surface); border: 1px solid var(--color-border);">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </a>
              <a href="https://github.com/nick" target="_blank" rel="noopener"
                class="p-3 rounded-lg transition-all hover:-translate-y-1"
                style="background: var(--color-bg-surface); border: 1px solid var(--color-border);">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
              </a>
              <a href="mailto:nick@example.com"
                class="p-3 rounded-lg transition-all hover:-translate-y-1"
                style="background: var(--color-bg-surface); border: 1px solid var(--color-border);">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </a>
            </div>

            <!-- Resume Download Button -->
            <a href="/resume/Nick_Stafford_Resume.pdf" download
              class="inline-flex items-center gap-2 px-6 py-3 rounded-xl transition-all hover:-translate-y-1 group"
              style="background: var(--gradient-primary); margin-top: 16px;">
              <svg class="w-5 h-5 text-white transition-transform group-hover:scale-110" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              <span class="text-white font-medium">Download Resume</span>
            </a>
          </div>
        </div>

        <!-- Stats grid -->
        <div class="grid grid-cols-3 gap-4">
          <div class="glass-card text-center py-6">
            <div class="text-3xl font-bold gradient-text">5+</div>
            <p class="text-sm mt-1" style="color: var(--color-text-muted);">Years Experience</p>
          </div>
          <div class="glass-card text-center py-6">
            <div class="text-3xl font-bold gradient-text">25+</div>
            <p class="text-sm mt-1" style="color: var(--color-text-muted);">Integrations<br>Built</p>
          </div>
          <div class="glass-card text-center py-6">
            <div class="text-3xl font-bold gradient-text">10+</div>
            <p class="text-sm mt-1" style="color: var(--color-text-muted);">AI<br>Systems</p>
          </div>
        </div>
      </div>

      <!-- Right column: About text and skills -->
      <div class="space-y-8">
        <div>
          <span class="section-label">About Me</span>
          <h2 class="text-4xl font-bold mt-4 mb-6" style="color: var(--color-text-primary);">
            Building the Future of <span class="gradient-text">Financial Technology</span>
          </h2>
          <div class="space-y-4" style="color: var(--color-text-secondary);">
            <p>
              I'm a Solutions Architect and AI Engineer based in Seattle, specializing in building
              intelligent systems that transform how we interact with financial data.
            </p>
            <p>
              With a background spanning Salesforce development, financial automation, and
              cutting-edge AI/ML projects, I bring a unique perspective to solving complex
              business problems with technology.
            </p>
            <p>
              My current focus is on leveraging large language models and quantitative analysis
              to create tools that make sophisticated financial insights accessible to everyone.
            </p>
          </div>
        </div>

        <!-- Skills -->
        <div id="skills" class="pt-8">
          <h3 class="text-xl font-bold mb-6" style="color: var(--color-text-primary);">Technical Skills</h3>

          <!-- Skill categories -->
          <div class="space-y-6">
            <!-- Languages & Frameworks -->
            <div>
              <h4 class="text-sm font-medium mb-3" style="color: var(--color-accent-primary);">Languages & Frameworks</h4>
              <div class="flex flex-wrap gap-2">
                {['Python', 'TypeScript', 'React', 'Node.js', 'SQL', 'Apex'].map(skill => (
                  <span class="skill-tag">{skill}</span>
                ))}
              </div>
            </div>

            <!-- AI/ML -->
            <div>
              <h4 class="text-sm font-medium mb-3" style="color: var(--color-accent-primary);">AI & Machine Learning</h4>
              <div class="flex flex-wrap gap-2">
                {['LLM Integration', 'Prompt Engineering', 'Vector Databases', 'RAG Systems', 'Sentiment Analysis'].map(skill => (
                  <span class="skill-tag">{skill}</span>
                ))}
              </div>
            </div>

            <!-- Financial -->
            <div>
              <h4 class="text-sm font-medium mb-3" style="color: var(--color-accent-primary);">Financial Engineering</h4>
              <div class="flex flex-wrap gap-2">
                {['Quantitative Analysis', 'Technical Indicators', 'Risk Metrics', 'Portfolio Theory', 'Market Data APIs'].map(skill => (
                  <span class="skill-tag">{skill}</span>
                ))}
              </div>
            </div>

            <!-- Infrastructure -->
            <div>
              <h4 class="text-sm font-medium mb-3" style="color: var(--color-accent-primary);">Infrastructure & Tools</h4>
              <div class="flex flex-wrap gap-2">
                {['Salesforce', 'AWS', 'Docker', 'Git', 'FastAPI', 'Streamlit'].map(skill => (
                  <span class="skill-tag">{skill}</span>
                ))}
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .skill-tag {
    padding: 0.5rem 1rem;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    transition: all 0.2s ease;
  }

  .skill-tag:hover {
    border-color: var(--color-accent-primary);
    color: var(--color-accent-primary);
    transform: translateY(-2px);
  }
</style>
